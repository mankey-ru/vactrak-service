# Create a bot (https://t.me/BotFather), then open a chat with it and send /start. It needed for ability to receive messages from the bot you created
TELEGRAM_BOT_TOKEN=
# Fallback chat for notifications when user telegram id is unavailable (legacy solo mode)
TELEGRAM_CHAT_ID=

# JWT for browser/Nuxt sessions (Telegram Login Widget → POST /api/auth/telegram)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated Nuxt origins allowed by CORS (prod). Leave empty to reflect any origin in dev.
WEB_ORIGIN=http://localhost:3001

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=vactrak_user
POSTGRES_PASSWORD=
POSTGRES_DB=vactrak_db
# true on Render Postgres (auto if host contains render.com). false for local Docker.
POSTGRES_SSL=false

DB_SYNCHRONIZE=true  # Только для dev! В prod — false + миграции
DB_LOGGING=true
