# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4
quote_type = single
curly_bracket_next_line = false
# max_line_length нужно чтобы не разбивались длинные инлайн стрелочные функции (по умолчанию 80)
max_line_length = 100

[*.{yml,yaml,md,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.svg]
insert_final_newline = false
